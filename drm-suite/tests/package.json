{
  "name": "drm-suite-tests",
  "version": "1.0.0",
  "description": "DRM Suite v1.0 Tests",
  "scripts": {
    "test": "jest",
    "test:smoke": "jest smoke-test.spec.ts",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "axios": "^1.6.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.spec.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/../$1"
    }
  }
}