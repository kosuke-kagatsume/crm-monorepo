// ==================== v1.0 新機能: 工事台帳システム ====================
model ProjectLedger {
  id               String   @id @default(cuid())
  companyId        String
  storeId          String?
  projectId        String   @unique // 見積・契約IDとリンク
  customerId       String
  contractAmount   Decimal
  billingMode      String   // MILESTONE, PERCENT_COMPLETE
  retainagePct     Decimal  @default(5.0) // 保留金率
  retainageReleaseRule String @default("ON_FINAL") // ON_FINAL, ON_INSPECTION
  status           String   @default("active") // active, completed, cancelled
  dwSyncStatus     String   @default("pending") // DW連携ステータス
  dwSyncAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  company          Company             @relation(fields: [companyId], references: [id])
  store            Store?              @relation(fields: [storeId], references: [id])
  customer         Customer            @relation(fields: [customerId], references: [id])
  subLedgers       LedgerSub[]
  changeOrders     ChangeOrder[]
  retainage        Retainage?
  milestoneBilling MilestoneBilling[]
  contractHistory  ContractHistory[]
  budgetRevisions  BudgetRevision[]
  invoices         Invoice[]
  retentionReleases RetentionRelease[]

  @@index([companyId])
  @@index([projectId])
  @@index([customerId])
  @@map("project_ledgers")
}

model LedgerSub {
  id         String   @id @default(cuid())
  ledgerId   String
  tradeCode  String   // 工種コード
  name       String
  seq        Int      // 連番
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  ledger    ProjectLedger  @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  budgets   LedgerBudget[]
  costs     LedgerCost[]
  progress  LedgerProgress[]
  invoiceLines InvoiceLine[]

  @@unique([ledgerId, tradeCode, seq])
  @@index([ledgerId])
  @@map("ledger_subs")
}

model LedgerBudget {
  id          String   @id @default(cuid())
  subId       String
  costCode    String   // 原価コード
  costName    String
  plannedQty  Decimal?
  unit        String?
  plannedAmt  Decimal
  taxCode     String   @default("10") // 10%, 8%, non-taxable
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sub LedgerSub @relation(fields: [subId], references: [id], onDelete: Cascade)

  @@index([subId])
  @@index([costCode])
  @@map("ledger_budgets")
}

model LedgerCost {
  id          String   @id @default(cuid())
  subId       String
  docType     String   // MATERIAL, OUTSOURCE, LABOR
  vendorId    String?
  vendorName  String
  description String
  quantity    Decimal?
  unit        String?
  unitPrice   Decimal?
  amount      Decimal
  taxCode     String   @default("10")
  taxAmount   Decimal  @default(0)
  invoiceNo   String?
  invoiceDate DateTime?
  paymentDate DateTime?
  source      String   @default("MANUAL") // DW, UPLOAD, MANUAL
  sourceRef   String?  // Reference to source system
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sub LedgerSub @relation(fields: [subId], references: [id], onDelete: Cascade)

  @@index([subId])
  @@index([vendorId])
  @@index([invoiceDate])
  @@map("ledger_costs")
}

model LedgerProgress {
  id             String   @id @default(cuid())
  subId          String
  date           DateTime
  progressPct    Decimal  // 進捗率
