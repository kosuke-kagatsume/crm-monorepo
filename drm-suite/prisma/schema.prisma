// --- テナント設定（Lite/Standard/Pro） ---
model CompanyPlan {
  companyId   String   @id
  plan        String   @default("LITE") // LITE, STANDARD, PRO
  features    String   @default("{}") // JSON: {"retention": true, "co": true, "detailedExport": false}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_plans")
