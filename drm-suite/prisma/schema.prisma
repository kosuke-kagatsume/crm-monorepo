// Plan enum replaced with String for SQLite compatibility
// Values: "LITE", "STANDARD", "PRO"

// --- 契約と工期の履歴（ど真ん中） ---
model ContractHistory {
  id           String   @id @default(cuid())
  ledgerId     String
  version      Int
  contractAmt  Decimal  // 変更後の契約金額
  durationDays Int?     // 工期変更も記録（任意）
  reason       String?
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())

  // Relations
  ledger       ProjectLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  approver     User?         @relation("ContractHistoryApprover", fields: [approvedBy], references: [id])

  @@index([ledgerId])
  @@index([version])
  @@map("contract_history")
}

// --- 実行予算リビジョン（見積→契約→実行の差分管理） ---
model BudgetRevision {
  id          String   @id @default(cuid())
  ledgerId    String
  revisionNo  Int
  note        String?
  createdBy   String
  createdAt   DateTime @default(now())

  // Relations
  ledger      ProjectLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  creator     User          @relation(fields: [createdBy], references: [id])

  @@unique([ledgerId, revisionNo])
  @@index([ledgerId])
  @@map("budget_revisions")
}

// --- 出来高 承認ログ（監査） ---
model ProgressApprovalLog {
  id          String   @id @default(cuid())
  progressId  String
  approvedBy  String
  level       Int      // 1=現場, 2=所長, 3=本部
  approvedAt  DateTime @default(now())
  comment     String?

  // Relations
  progress    LedgerProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  approver    User           @relation(fields: [approvedBy], references: [id])

  @@index([progressId])
  @@index([approvedBy])
  @@map("progress_approval_logs")
}

// --- 請求・入金（会計と突合しやすいヘッダー明細） ---
model Invoice {
  id            String   @id @default(cuid())
  ledgerId      String
  invoiceNo     String
  billType      String   // MILESTONE | PERCENT | RETAINAGE_RELEASE
  billPeriod    String?  // "2025-08" 等
  totalAmt      Decimal
  taxAmt        Decimal? // 必要なら
  status        String     @default("DRAFT") // DRAFT | ISSUED | PAID | PARTIAL | CANCELED
  issuedAt      DateTime?
  dueDate       DateTime?
  createdAt     DateTime @default(now())

  // Relations
  ledger        ProjectLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  invoiceLines  InvoiceLine[]
  payments      Payment[]

  @@unique([invoiceNo])
  @@index([ledgerId])
  @@index([status])
  @@map("invoices")
}

// BillType enum replaced with String for SQLite compatibility
// Values: "MILESTONE", "PERCENT", "RETAINAGE_RELEASE"

// BillStatus enum replaced with String for SQLite compatibility  
// Values: "DRAFT", "ISSUED", "PAID", "PARTIAL", "CANCELED"

model InvoiceLine {
  id          String   @id @default(cuid())
