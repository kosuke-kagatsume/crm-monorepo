  subId       String?  // 工種別に行を出す場合
  description String?
  qty         Decimal? 
  unitPrice   Decimal?
  amount      Decimal
  taxCode     String?

  // Relations
  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sub         LedgerSub? @relation(fields: [subId], references: [id])

  @@index([invoiceId])
  @@map("invoice_lines")
}

// 入金（回収）記録
model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  paidAmt     Decimal
  paidAt      DateTime
  method      String?   // 振込/現金/カード 等
  note        String?
  createdAt   DateTime @default(now())

  // Relations
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paidAt])
  @@map("payments")
}

// 保留金の解放イベント（いついくら解いたか）
model RetentionRelease {
  id          String   @id @default(cuid())
  ledgerId    String
  releaseAmt  Decimal
  reason      String?   // 最終検収/保証書発行など
  releasedAt  DateTime  @default(now())

  // Relations
  ledger      ProjectLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)

  @@index([ledgerId])
  @@index([releasedAt])
  @@map("retention_releases")
}
